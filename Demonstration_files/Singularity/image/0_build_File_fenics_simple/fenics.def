Bootstrap: docker
From: fenics/stable:py3

%post
    apt-get update
    apt-get install -y \
        nano \
        python3-matplotlib

    apt-get clean
    rm -rf /var/lib/apt/lists/*

    mkdir -p /workspace

%environment
    export WORKDIR=/workspace

%runscript
    exec /bin/bash "$@"

%startscript
    exec /bin/bash


%help
    FEniCS container based on fenics/stable:py3
    Additional packages:
      - nano
      - python3-matplotlib